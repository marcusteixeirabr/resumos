---
import { getCollection, render } from 'astro:content';
import DisciplineLayout from '../../layouts/DisciplineLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('software-design');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props:  { entry, entries },
  }));
}

const { entry, entries } = Astro.props;
const { Content } = await render(entry);
const sorted = [...entries].sort((a, b) => a.data.ua - b.data.ua);
---
<DisciplineLayout
  entry={entry}
  entries={sorted}
  disciplineTitle="Software Design"
  base="/software-design"
>
  <Content />
</DisciplineLayout>
