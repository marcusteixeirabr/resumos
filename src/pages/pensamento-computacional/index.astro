---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Pensamento Computacional — Resumos ADS" cssFiles={['discipline.css']}>
  <header>
    <a class="back" href={`${base}/`}>Início</a>
    <h1>Pensamento Computacional</h1>
    <button class="search-btn" id="search-btn" aria-label="Buscar (Ctrl+K)">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <span class="search-btn-label">Buscar</span><kbd>Ctrl K</kbd>
    </button>
  </header>
  <main class="wip" data-pagefind-ignore>
    <div class="wip-icon" style="background: rgba(247,129,102,0.1); color: var(--accent3);">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>
    </div>
    <h2 class="wip-title">Resumos em preparação</h2>
    <p class="wip-desc">Os resumos desta disciplina estão sendo elaborados. Em breve você encontrará conteúdo completo sobre regras de negócio, requisitos funcionais e não funcionais, casos de uso e rastreabilidade.</p>
    <div class="wip-chips">
      <span class="wip-chip">RF / RNF</span><span class="wip-chip">Caso de Uso</span>
      <span class="wip-chip">Regras de Negócio</span><span class="wip-chip">Diagrama de Atividades</span>
      <span class="wip-chip">Rastreabilidade</span><span class="wip-chip">UML</span>
    </div>
    <div class="wip-progress"><div class="wip-progress-fill" style="width: 15%;"></div></div>
    <p class="wip-progress-label">15% — em breve</p>
    <a class="wip-back" href={`${base}/`}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Voltar ao início
    </a>
  </main>
</BaseLayout>
